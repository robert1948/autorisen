.PHONY: deps predeploy heroku-login heroku-push heroku-release heroku-deploy heroku-logs \
        heroku-open hosts-sync print-host \
        smoke smoke-local up down clean rebuild logs be-logs fe-logs ps tools psql \
        update-git status-new weekly-new deploy-dev

# -------------------------
# App / Host configuration
# -------------------------
# Override at call time:
#   HEROKU_APP=my-app make heroku-deploy
HEROKU_APP ?= autorisen

# Prefer explicit HOST=example.herokuapp.com, else auto-detect from Heroku,
# else fall back to <app>.herokuapp.com.
HEROKU_HOST := $(shell heroku apps:info -a $(HEROKU_APP) 2>/dev/null | sed -n 's/Web URL:[[:space:]]*https\?:\/\/\([^\/]*\)\/.*/\1/p')
SMOKE_HOST  := $(if $(HOST),$(HOST),$(if $(HEROKU_HOST),$(HEROKU_HOST),$(HEROKU_APP).herokuapp.com))

# -------------------------
# Python deps (local dev)
# -------------------------
deps:
	python -m pip install -r requirements.txt || true
	python -m pip install -r backend/requirements.txt || true

# -------------------------
# Pre-deployment gate
# -------------------------
predeploy:
	bash scripts/predeploy_gate.sh

# -------------------------
# Heroku (Container Deploy)
# -------------------------
heroku-login:
	heroku container:login

heroku-push: heroku-login
	heroku container:push web -a $(HEROKU_APP)

heroku-release:
	heroku container:release web -a $(HEROKU_APP)

# alias
deploy-dev: heroku-deploy

heroku-deploy: predeploy heroku-push heroku-release
	@echo "✅ Deployed to Heroku app $(HEROKU_APP)"

heroku-logs:
	heroku logs --tail -a $(HEROKU_APP)

heroku-open:
	heroku open -a $(HEROKU_APP)

print-host:
	@echo "HEROKU_APP = $(HEROKU_APP)"
	@echo "Detected HEROKU_HOST = $(HEROKU_HOST)"
	@echo "SMOKE_HOST = $(SMOKE_HOST)"

# Sync HOST/CORS/API URLs to the real hostname.
# Usage:
#   make hosts-sync                 # uses detected host from Heroku
#   HOST=my.custom.host make hosts-sync  # force a specific host
hosts-sync:
	@set -e; \
	HOST="$(SMOKE_HOST)"; \
	LEGACY="$(HEROKU_APP).herokuapp.com"; \
	ALLOWED="$$HOST"; \
	if [ "$$HOST" != "$$LEGACY" ]; then ALLOWED="$$HOST,$$LEGACY"; fi; \
	echo "🔧 Setting host config for: $$HOST (allowed: $$ALLOWED)"; \
	heroku config:set \
	  ALLOWED_HOSTS="$$ALLOWED" \
	  CORS_ORIGINS="https://$$HOST" \
	  CLIENT_URL="https://$$HOST" \
	  REACT_APP_API_URL="https://$$HOST/api" \
	  GOOGLE_CALLBACK_URL="https://$$HOST/api/auth/google/callback" \
	  LINKEDIN_CALLBACK_URL="https://$$HOST/api/auth/linkedin/callback" \
	  -a $(HEROKU_APP)

# -------------------------
# Smoke tests
# -------------------------
# Cloud smoke: tries /api/health, /health, and /; prints status codes and succeeds on first 200
smoke: print-host
	@echo "🔎 Smoking: https://$(SMOKE_HOST)"
	@set -e; \
	for path in /api/health /health /; do \
	  code=$$(curl -sS --max-time 10 -o /dev/null -w "%{http_code}" "https://$(SMOKE_HOST)$$path"); \
	  echo "→ GET $$path -> $$code"; \
	  if [ "$$code" = "200" ]; then \
	    echo "✅ Healthy at $$path"; \
	    exit 0; \
	  fi; \
	done; \
	echo "❌ Not healthy at /api/health or /health (see codes above)"; \
	exit 1

# Local smoke: checks your dev stack at http://localhost:8000
smoke-local:
	@echo "🔎 Smoking local: http://localhost:8000"
	@set -e; \
	for path in /api/health /health /; do \
	  code=$$(curl -sS --max-time 10 -o /dev/null -w "%{http_code}" "http://localhost:8000$$path"); \
	  echo "→ GET $$path -> $$code"; \
	  if [ "$$code" = "200" ]; then \
	    echo "✅ Healthy locally at $$path"; \
	    exit 0; \
	  fi; \
	done; \
	echo "❌ Local API not healthy at /api/health or /health (see codes above)"; \
	exit 1

# -------------------------
# Local Development (Docker Compose)
# -------------------------
up:
	docker compose up -d

down:
	docker compose down --remove-orphans

clean:
	@read -p "⚠️  This will REMOVE ALL VOLUMES and wipe data. Continue? (y/N) " ans; \
	if [ "$$ans" = "y" ] || [ "$$ans" = "Y" ]; then \
		docker compose down -v --remove-orphans; \
	else \
		echo "❌ Aborted clean."; \
	fi

rebuild:
	docker compose build --no-cache

logs:
	docker compose logs -f --tail=200

be-logs:
	docker compose logs -f backend

fe-logs:
	docker compose logs -f frontend

ps:
	docker compose ps

# Start optional tools (pgAdmin + Redis Commander)
tools:
	docker compose --profile tools up -d

# psql shortcut into the dev Postgres
psql:
	PGPASSWORD=$${POSTGRES_PASSWORD} psql -h 127.0.0.1 -p 5433 -U $${POSTGRES_USER} -d $${POSTGRES_DB}

# -------------------------
# Git helpers
# -------------------------
update-git:
	@git status -sb
	@echo "🔄 Staging all changes..."
	git add .
	@echo "✍️  Committing (with [skip ci])..."
	git commit -m "chore: update local changes [skip ci]" || true
	@echo "⬆️  Pushing to GitHub (autorisen repo)..."
	git push origin main
	@echo "✅ Update pushed (CI skipped)."

# -------------------------
# Status files (optional)
# -------------------------
DATE := $(shell date +%F)
WEEK := $(shell date +%G-%V)

status-new:
	mkdir -p docs/status
	test -f docs/status/STATUS_TEMPLATE.md && cp docs/status/STATUS_TEMPLATE.md docs/status/STATUS_$(DATE).md || \
	printf "# Daily Status — $(DATE)\n" > docs/status/STATUS_$(DATE).md
	@echo "📝 Created docs/status/STATUS_$(DATE).md"

weekly-new:
	mkdir -p docs/status
	test -f docs/status/WEEKLY_TEMPLATE.md && cp docs/status/WEEKLY_TEMPLATE.md docs/status/WEEKLY_$(WEEK).md || \
	printf "# Weekly Roll-Up — $(WEEK)\n" > docs/status/WEEKLY_$(WEEK).md
	@echo "🗓  Created docs/status/WEEKLY_$(WEEK).md"
