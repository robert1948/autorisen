# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/
.mypy_cache/
.pytest_cache/
.coverage
.coverage.*
coverage/
htmlcov/
.tox/
.venv/
venv/
.python-version
.ruff_cache/
coverage.xml

# Build artifacts (wheel / sdist leftovers)
*.whl
*.tar.gz

# Frontend tooling caches
.vite/
client/.vite/
client/.eslintcache

# Profiling / debugging
profiling/
*.prof
pytestdebug.log

# Local VSCode history
.history/

# --- Environment files (do NOT commit secrets) ---
.env
.env.*
.env.local
!.env.example
!.env.*.example

# --- SQLite / Local DBs ---
*.sqlite3
test*.db

# --- PostgreSQL / Database files ---
*.dump
*.sql.backup
pgdata/
postgres-data/

# --- Node / JavaScript (client) ---
node_modules/
client/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.parcel-cache/
.next/
.nuxt/
out/
client/.cache/
client/build/
client/dist/
client/coverage/

# --- Logs ---
logs/
*.log

# --- Editors / IDE ---
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo

# --- System / Misc ---
.DS_Store
Thumbs.db

# --- Test / Temp ---
.cache/
tmp/
temp/

# --- Docker / Devcontainers Artifacts ---
.devcontainer/
**/.devcontainer/local-history/
Dockerfile.dev
docker-compose*.override.yml

# Explicitly keep infra files
!docker-compose.yml
!Dockerfile

# Keep example envs only (already handled above); avoid redeclaring broad .env* ignores
.env.development.local
.env.test.local

