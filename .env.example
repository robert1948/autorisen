# ================================
# Autorisen / CapeControl - Example Env File
# Copy this to `.env` and fill values
# ================================

# ---------- Admin Bootstrap (optional for dev) ----------
ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong

# ---------- Security ----------
SECRET_KEY=replace-with-strong-random
JWT_SECRET_KEY=replace-with-strong-random

# ---------- Environment ----------
ENVIRONMENT=development   # development | staging | production
DEBUG=true
LOG_LEVEL=INFO
NODE_ENV=development
WEB_CONCURRENCY=2

# ---------- Hosts & CORS ----------
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CLIENT_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------- Database ----------
# Option 1: SQLite (simple dev/testing)
# DATABASE_URL=sqlite:///./dev.db

# Option 2: Local PostgreSQL (recommended for dev/prod parity)
DATABASE_URL=postgresql+psycopg2://autorisen_user:change-me@db:5432/autorisen

# Option 3: External/Heroku PostgreSQL
# DATABASE_URL=postgres://user:password@host:port/database

POSTGRES_DB=autorisen
POSTGRES_USER=autorisen_user
POSTGRES_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

# ---------- Redis ----------
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# ---------- Email / SMTP ----------
FROM_EMAIL=no-reply@capecraft.ai
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=change-me

# ---------- AWS / S3 (optional) ----------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=us-east-1
AWS_STORAGE_BUCKET_NAME=lightning-s3

# ---------- Payment Integrations ----------
# Stripe
ENABLE_STRIPE=false
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
WEBHOOK=

# PayFast
ENABLE_PAYFAST=false
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_MODE=sandbox
PAYFAST_NOTIFY_URL=http://localhost:8000/api/payfast/notify
PAYFAST_RETURN_URL=http://localhost:3000/payment/success
PAYFAST_CANCEL_URL=http://localhost:3000/payment/cancel

# ---------- OAuth (optional) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=http://localhost:8000/api/auth/linkedin/callback

# ---------- AI Providers (optional) ----------
OPENAI_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=

# ---------- Perf / Monitoring ----------
ENABLE_PERF_SAMPLER=false
PERF_SAMPLE_SECONDS=30
